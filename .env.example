# ─── StadiumMind AI — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Flask Core ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
FLASK_ENV=development
FLASK_DEBUG=true

# ── Google Gemini API ──────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── AI Behaviour ───────────────────────────────────────────────────────────────
# Set to "true" to run without a real API key (uses mock AI responses)
MOCK_AI=false
AI_CACHE_TTL=300
AI_MAX_TOKENS=1024
AI_MODEL=gemini-1.5-flash

# ── Data ───────────────────────────────────────────────────────────────────────
DATA_DIR=data

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_TO_FILE=false
LOG_FILE=logs/stadiumind.log
